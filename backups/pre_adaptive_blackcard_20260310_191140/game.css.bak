/* =====================================================
   Terrible People - Neon Glass UI
   (UTF-8 no BOM)
===================================================== */

:root{
  --bg0:#06060a;
  --bg1:#0b0b14;
  --card:rgba(255,255,255,0.06);
  --card2:rgba(255,255,255,0.09);
  --stroke:rgba(233,236,255,0.14);
  --text:rgba(233,236,255,0.92);
  --muted:rgba(233,236,255,0.62);
  --green:rgba(34,255,72,0.95);
  --purple:rgba(149,88,255,0.95);
  --red:rgba(255,70,70,0.90);
  --tp-card-width: clamp(98px, 13vw, 160px);
  --tp-card-radius: 14px;
  --tp-card-pad: clamp(8px, 1vw, 12px);
}

*{ box-sizing:border-box; }

html,body{
  height:100%;
  margin:0;
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color:var(--text);
  background:
    radial-gradient(1200px 600px at 12% 0%, rgba(149,88,255,0.16), transparent 60%),
    radial-gradient(900px 600px at 85% 10%, rgba(34,255,72,0.14), transparent 55%),
    linear-gradient(180deg, var(--bg0), var(--bg1));
}

.theme{ padding: 16px; }

.topbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:12px 14px;
  border:1px solid var(--stroke);
  border-radius:18px;
  background:linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
  backdrop-filter: blur(12px);
  box-shadow: 0 0 22px rgba(0,0,0,0.35);
  margin-bottom: 14px;
}

.brand{ display:flex; align-items:center; gap:12px; }
.logo{
  width:42px; height:42px;
  border-radius:14px;
  display:grid; place-items:center;
  font-weight:900;
  letter-spacing:0.08em;
  color:#001503;
  background: radial-gradient(circle at 0 0, rgba(34,255,72,0.8), rgba(149,88,255,0.65));
  border:1px solid rgba(34,255,72,0.35);
  box-shadow: 0 0 18px rgba(34,255,72,0.18);
}

.titles .h1{ font-size: 18px; font-weight: 900; letter-spacing:0.06em; }
.titles .h2{ font-size: 12px; color: var(--muted); letter-spacing:0.10em; text-transform:uppercase; }

.right{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
.link{ color: rgba(233,236,255,0.85); text-decoration:none; font-weight:700; }
.link:hover{ color: white; }
.dot{ color: rgba(233,236,255,0.35); }

.pill{
  padding:6px 10px;
  border-radius:999px;
  border:1px solid var(--stroke);
  background: rgba(255,255,255,0.06);
  font-weight:800;
  letter-spacing:0.10em;
  font-size: 12px;
}

.grid{
  display:grid;
  grid-template-columns: 320px 1fr 360px;
  gap: 14px;
}

.minimalGrid{
  grid-template-columns: 1fr 320px;
}

@media (max-width: 1100px){
  .grid{ grid-template-columns: 1fr; }
  .minimalGrid{ grid-template-columns: 1fr; }
}

.card{
  border:1px solid var(--stroke);
  border-radius:18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
  backdrop-filter: blur(12px);
  box-shadow: 0 0 22px rgba(0,0,0,0.35);
  padding: 12px;
}

.cardHead{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom: 10px;
}

.cardTitle{
  font-weight: 900;
  letter-spacing:0.10em;
  text-transform: uppercase;
  font-size: 12px;
  color: rgba(233,236,255,0.85);
}

.cardMeta{
  font-size: 12px;
  color: var(--muted);
}

.tpCard{
  width: var(--tp-card-width);
  aspect-ratio: 5 / 7;
  min-height: 0;
  border-radius: var(--tp-card-radius);
  padding: var(--tp-card-pad);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  overflow: hidden;
  word-break: break-word;
  white-space: normal;
  line-height: 1.22;
  font-weight: 800;
  text-align: left;
  transform-origin: center center;
  transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
}

.tpCard--white{
  border: 2px solid #e6e6e6;
  background: #ffffff;
  color: #101114;
  box-shadow: 0 8px 18px rgba(0,0,0,0.25);
}

.tpCard--black{
  border: 2px solid #111;
  background: #0a0a0a;
  color: #fff;
  box-shadow: 0 10px 22px rgba(0,0,0,0.35);
}

.tpCard--submission{
  margin-bottom: 0;
}

.tpCard--back,
.cardBack,
.faceDownCard{
  border: 2px solid #111;
  background: #0a0a0a url('/images/Terrible_Peolpe_Logo.png') center / cover no-repeat;
  color: transparent;
  box-shadow: 0 10px 22px rgba(0,0,0,0.35);
}

.blackCard{
  width: calc(var(--tp-card-width) * 1.2);
  margin: 0 auto 12px auto;
  font-size: clamp(14px, 1.8vw, 20px);
}

.boardRow{
  display:flex;
  align-items:flex-start;
  justify-content:flex-start;
  gap:14px;
  flex-wrap:wrap;
  margin-bottom: 10px;
}

.boardBlack{
  flex: 0 0 auto;
}

.submissionsWrap{
  flex: 1 1 380px;
  min-height: calc((var(--tp-card-width) * 7 / 5) + 8px);
}

@media (max-width: 900px){
  .boardRow{
    gap:10px;
  }
  .boardBlack,
  .submissionsWrap{
    flex: 1 1 100%;
  }
  .boardBlack{
    display:flex;
    justify-content:center;
  }
}


.playersList{
  display:flex;
  flex-direction:column;
  gap:8px;
}

.playerRow{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding:10px 10px;
  border-radius:14px;
  border:1px solid rgba(233,236,255,0.10);
  background: rgba(0,0,0,0.20);
}

.playerLeft{ display:flex; align-items:center; gap:10px; min-width:0; }
.playerName{
  font-weight: 900;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  max-width: 170px;
}
.playerBadges{ display:flex; gap:6px; flex-wrap:wrap; }
.badge{
  font-size: 11px;
  font-weight: 900;
  letter-spacing:0.10em;
  padding:4px 8px;
  border-radius:999px;
  border:1px solid rgba(233,236,255,0.14);
  background: rgba(255,255,255,0.06);
  color: rgba(233,236,255,0.88);
  text-transform: uppercase;
}

.badge.host{
  border-color: rgba(149,88,255,0.45);
  box-shadow: 0 0 16px rgba(149,88,255,0.14);
}

.badge.crown{
  border-color: rgba(34,255,72,0.45);
  box-shadow: 0 0 16px rgba(34,255,72,0.14);
}

.badge.bot{
  border-color: rgba(233,236,255,0.22);
  opacity: 0.85;
}

.playerScore{
  font-weight: 900;
  letter-spacing:0.10em;
  color: rgba(233,236,255,0.90);
}

.handWrap{ margin-top: 10px; }
.handHead{ display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }

.handList{
  display:flex;
  flex-wrap:wrap;
  align-items:flex-start;
  justify-content:flex-start;
  gap:10px;
  overflow-x:hidden;
}

@media (max-width: 700px){
  .handList{
    justify-content:center;
    gap:8px;
  }
}

.cardWhite{
  cursor:pointer;
  user-select:none;
  font-size: clamp(12px, 1.3vw, 16px);
}

.cardWhite:hover{ transform: translateY(-1px); }
.cardWhite.disabled{ opacity:0.42; cursor:not-allowed; transform:none; }

.submissionsWrap{ margin-top: 8px; overflow: hidden; }
.subHead{ display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.subList{
  display:flex;
  flex-wrap:wrap;
  align-items:flex-start;
  justify-content:flex-start;
  gap:10px;
  overflow-x:hidden;
}

@media (max-width: 700px){
  .subList{
    justify-content:center;
    gap:8px;
  }
}

.subCard{
  cursor:pointer;
  font-size: clamp(12px, 1.25vw, 16px);
}

.subCard.disabled{ cursor:not-allowed; opacity:0.55; }

.chatLog{
  height: 420px;
  overflow:auto;
  border-radius: 14px;
  border:1px solid rgba(233,236,255,0.10);
  background: rgba(0,0,0,0.22);
  padding: 10px;
}

.minimal .chatLog{ height: 260px; }

.chatLine{ margin-bottom: 8px; }
.chatSys{ color: rgba(233,236,255,0.62); font-style: italic; }
.chatName{ font-weight: 900; color: rgba(233,236,255,0.92); }
.chatText{ color: rgba(233,236,255,0.88); }

.chatSend{
  display:flex;
  gap:10px;
  margin-top: 10px;
}

.input{
  width:100%;
  padding: 10px 12px;
  border-radius: 14px;
  border:1px solid rgba(233,236,255,0.16);
  background: rgba(0,0,0,0.22);
  color: rgba(233,236,255,0.92);
  outline:none;
  font-weight: 800;
}

.input:focus{
  border-color: rgba(34,255,72,0.45);
  box-shadow: 0 0 0 3px rgba(34,255,72,0.10);
}

.btn{
  padding: 10px 12px;
  border-radius: 14px;
  border:1px solid rgba(34,255,72,0.35);
  background: radial-gradient(circle at 0 0, rgba(34,255,72,0.55), rgba(149,88,255,0.50));
  color:#001503;
  font-weight: 900;
  letter-spacing:0.10em;
  text-transform: uppercase;
  cursor:pointer;
  user-select:none;
  white-space:nowrap;
}

.btn:hover{ filter: brightness(1.06); }
.btn:active{ transform: translateY(1px); }

.btn.ghost{
  background: rgba(255,255,255,0.06);
  color: rgba(233,236,255,0.88);
  border-color: rgba(233,236,255,0.14);
  letter-spacing:0.08em;
}

.btn.danger{
  border-color: rgba(255,70,70,0.55);
}

.rowGap{ display:flex; gap:10px; flex-wrap:wrap; }

.smallHint{
  margin-top: 8px;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.3;
}

.adminBox{
  margin-top: 12px;
  border-top: 1px solid rgba(233,236,255,0.12);
  padding-top: 12px;
}

.adminTitle{
  font-weight: 900;
  letter-spacing:0.12em;
  text-transform: uppercase;
  font-size: 12px;
  color: rgba(233,236,255,0.78);
  margin-bottom: 8px;
}

.adminRow{ display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 8px; }

.identityBox{
  margin-top: 12px;
  border-top: 1px solid rgba(233,236,255,0.12);
  padding-top: 10px;
}

.lobbyWrap{
  max-width: 520px;
  margin: 0 auto;
  display:flex;
  padding-top: 26px;
}

.label{
  display:block;
  margin: 10px 0 6px 0;
  color: rgba(233,236,255,0.74);
  font-weight: 900;
  letter-spacing:0.10em;
  text-transform: uppercase;
  font-size: 11px;
}

/* packs page rows (for your packs.html) */
.packsWrap{
  display:grid;
  grid-template-columns: 420px 1fr 420px;
  gap: 14px;
}
@media (max-width: 1100px){
  .packsWrap{ grid-template-columns: 1fr; }
}
.packsList{ display:flex; flex-direction:column; gap:10px; }
.packRow{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding:10px;
  border-radius:14px;
  border:1px solid rgba(233,236,255,0.10);
  background: rgba(0,0,0,0.20);
}
.packLeft{ min-width:0; }
.packName{ font-weight:900; }
.packMeta{ color: var(--muted); font-size:12px; margin-top:2px; }
.packToggle{ transform: scale(1.3); }
/* Redo top-banner dropdown layout */
.logo img{
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 2px;
  border-radius: 10px;
}

.theme{
  overflow: visible;
}

.topbar{
  position: relative;
  z-index: 4000;
  overflow: visible;
}

.right{
  overflow: visible;
  gap: 8px;
}

.navDrop{
  position: relative;
  z-index: 4100;
}

.navDropBtn{
  list-style: none;
  cursor: pointer;
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 10px;
  border-radius: 999px;
  border:1px solid var(--stroke);
  background: rgba(255,255,255,0.06);
  font-weight: 800;
  font-size: 12px;
  color: rgba(233,236,255,0.92);
}

.navDropBtn::-webkit-details-marker{ display:none; }

.pill.mini{
  padding: 2px 7px;
  font-size: 10px;
}

.navDrop[open]{ z-index: 4200; }

.navDropMenu{
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: min(420px, 92vw);
  max-height: 62vh;
  overflow: auto;
  z-index: 4300;
  border:1px solid var(--stroke);
  border-radius: 14px;
  padding: 10px;
  background: linear-gradient(180deg, rgba(18,22,34,0.98), rgba(10,12,20,0.98));
  box-shadow: 0 20px 34px rgba(0,0,0,0.45);
}

.chatMenu{
  width: min(520px, 95vw);
}

.chatMenu .chatLog{
  max-height: 300px;
}

.grid,
.minimalGrid{
  grid-template-columns: minmax(0,1fr) !important;
  grid-template-areas: "center" !important;
  grid-template-rows: minmax(0,1fr) !important;
}

@media (max-width: 1100px){
  .navDropMenu{
    right: auto;
    left: 0;
    width: min(94vw, 460px);
  }
}





.subList{
  perspective: 1000px;
}

.subCard{
  transform-style: preserve-3d;
  backface-visibility: hidden;
}

.subCard.is-flipping{
  animation: cardFlipIn 420ms cubic-bezier(0.2, 0.9, 0.25, 1) both;
}

.subCard.winner{
  outline: 2px solid rgba(34,255,72,0.7);
  box-shadow: 0 0 0 2px rgba(34,255,72,0.15), 0 10px 22px rgba(0,0,0,0.35);
  animation: winnerPulse 820ms ease;
}

.winnerTag{
  margin-top: auto;
  width: 100%;
  padding-top: 8px;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(24,26,35,0.75);
}

@keyframes cardFlipIn{
  0% { transform: rotateY(92deg) translateY(8px); opacity: 0; }
  100% { transform: rotateY(0deg) translateY(0); opacity: 1; }
}

@keyframes winnerPulse{
  0% { transform: scale(1); }
  45% { transform: scale(1.03); }
  100% { transform: scale(1); }
}


